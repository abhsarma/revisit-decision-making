        "trial": {
            "type": "react-component",
            "response": [{
                "id": "decision",
                "prompt": "Based on the forecast above, would you salt the road?",
                "required": true,
                "location": "belowStimulus",
                "type": "radio",
                "options": ["Yes", "No"]
            }, {
                "id": "prolificId",
                "prompt": "",
                "required": false,
                "hidden": true,
                "paramCapture": "PROLIFIC_PID",
                "type": "reactive"
